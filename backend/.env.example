PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/brainbank?appName=Cluster0

# JWT Authentication (use strong random secrets, 32+ chars in production)
JWT_SECRET=your_jwt_secret_here_at_least_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_at_least_32_chars

# AI PRD generation (Groq API)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Cloudinary media uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here

# CORS — comma-separated list of allowed frontend origins (besides localhost)
ALLOWED_ORIGINS=https://your-production-domain.com
